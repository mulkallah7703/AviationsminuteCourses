PORT=4000
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lms_auth

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long

# Access token TTL (e.g. 15m, 1h); refresh token TTL (e.g. 7d)
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Optional: restrict browser origin in production (comma-separated)
# CORS_ORIGIN=http://localhost:5173

# Login sets httpOnly cookie `lms_rt` (opaque refresh). SPA must call APIs with credentials (handled in frontend authApi).
