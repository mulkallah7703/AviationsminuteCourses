{
  "name": "aviationsminutenewcourse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run dev --prefix backend",
    "dev:full": "concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:api\"",
    "dev:vercel": "vercel dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "build": "prisma generate && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:secret": "node -e \"console.log(require('crypto').randomBytes(48).toString('hex'))\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "serverless-http": "^3.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.10"
  }
