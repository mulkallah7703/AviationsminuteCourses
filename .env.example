# =============================================================================
# Frontend (Vite) — optional. Copy to .env.local for local overrides.
# =============================================================================

# Leave UNSET on Vercel when API lives in the same project (recommended).
# The SPA calls same-origin /api/* — no localhost, no CORS.
#
# Only set this if your API is deployed on a SEPARATE domain:
# VITE_API_URL=https://your-api.example.com

# =============================================================================
# Vercel Serverless Functions — set in Vercel Dashboard → Environment Variables
# (NOT prefixed with VITE_ — these are server-side only)
# =============================================================================

# Hosted Postgres (Neon pooled URL recommended):
# DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/db?sslmode=require

# JWT secrets (>= 32 chars). Generate: npm run gen:secret
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=7d
