# =============================================================================
# Neon PostgreSQL — single DATABASE_URL for Prisma, Express API, and Vercel
# =============================================================================
# Use Neon pooled connection string (Dashboard → Connection details → Pooled):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# JWT secrets (>= 32 chars). Generate: npm run gen:secret
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# =============================================================================
# Frontend (Vite) — optional
# =============================================================================
# Leave UNSET on Vercel when API lives in the same project (same-origin /api/*).
# VITE_API_URL=https://your-api.example.com
